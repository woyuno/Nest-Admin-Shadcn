generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model SysConfig {
  configId    Int       @id @default(autoincrement()) @map("config_id")
  configName  String    @default("") @map("config_name") @db.VarChar(100)
  configKey   String    @default("") @map("config_key") @db.VarChar(100)
  configValue String    @default("") @map("config_value") @db.VarChar(500)
  configType  String    @default("N") @map("config_type") @db.Char(1)
  createBy    String    @default("") @map("create_by") @db.VarChar(64)
  createTime  DateTime? @default(now()) @map("create_time") @db.DateTime(6)
  updateBy    String    @default("") @map("update_by") @db.VarChar(64)
  updateTime  DateTime? @default(now()) @map("update_time") @db.DateTime(6)
  remark      String?   @db.VarChar(500)
  status      String    @default("0") @db.Char(1)
  delFlag     String    @default("0") @map("del_flag") @db.Char(1)

  @@map("sys_config")
}

model SysDept {
  deptId       Int           @id @default(autoincrement()) @map("dept_id")
  parentId     Int           @default(0) @map("parent_id")
  ancestors    String        @default("0") @db.VarChar(50)
  deptName     String        @map("dept_name") @db.VarChar(30)
  orderNum     Int           @default(0) @map("order_num")
  leader       String        @db.VarChar(20)
  phone        String        @default("") @db.VarChar(11)
  email        String        @default("") @db.VarChar(50)
  status       String        @default("0") @db.Char(1)
  delFlag      String        @default("0") @map("del_flag") @db.Char(1)
  createBy     String        @default("") @map("create_by") @db.VarChar(64)
  createTime   DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy     String        @default("") @map("update_by") @db.VarChar(64)
  updateTime   DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark       String?       @db.VarChar(500)
  roleBindings SysRoleDept[]
  users        SysUser[]

  @@map("sys_dept")
}

model SysDictData {
  dictCode    Int          @id @default(autoincrement()) @map("dict_code")
  dictSort    Int          @default(0) @map("dict_sort")
  dictLabel   String       @map("dict_label") @db.VarChar(100)
  dictValue   String       @map("dict_value") @db.VarChar(100)
  dictType    String       @map("dict_type") @db.VarChar(100)
  cssClass    String       @default("") @map("css_class") @db.VarChar(100)
  listClass   String       @map("list_class") @db.VarChar(100)
  isDefault   String       @default("N") @map("is_default") @db.Char(1)
  status      String       @default("0") @db.Char(1)
  createBy    String       @default("") @map("create_by") @db.VarChar(64)
  createTime  DateTime?    @default(now()) @map("create_time") @db.DateTime(6)
  updateBy    String       @default("") @map("update_by") @db.VarChar(64)
  updateTime  DateTime?    @default(now()) @map("update_time") @db.DateTime(6)
  remark      String?      @db.VarChar(500)
  delFlag     String       @default("0") @map("del_flag") @db.Char(1)
  dictTypeRef SysDictType? @relation(fields: [dictType], references: [dictType])

  @@map("sys_dict_data")
}

model SysDictType {
  dictId     Int           @id @default(autoincrement()) @map("dict_id")
  dictName   String        @map("dict_name") @db.VarChar(100)
  dictType   String        @unique(map: "IDX_f4e4273658733a3bbe6a2479bf") @map("dict_type") @db.VarChar(100)
  status     String        @default("0") @db.Char(1)
  createBy   String        @default("") @map("create_by") @db.VarChar(64)
  createTime DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy   String        @default("") @map("update_by") @db.VarChar(64)
  updateTime DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark     String?       @db.VarChar(500)
  delFlag    String        @default("0") @map("del_flag") @db.Char(1)
  dictData   SysDictData[]

  @@map("sys_dict_type")
}

model SysJob {
  jobId          Int       @id @default(autoincrement()) @map("job_id")
  jobName        String    @map("job_name") @db.VarChar(64)
  jobGroup       String    @default("DEFAULT") @map("job_group") @db.VarChar(64)
  invokeTarget   String    @map("invoke_target") @db.VarChar(500)
  cronExpression String?   @map("cron_expression") @db.VarChar(255)
  misfirePolicy  String?   @default("3") @map("misfire_policy") @db.VarChar(20)
  concurrent     String?   @default("1") @db.Char(1)
  status         String    @default("0") @db.Char(1)
  createBy       String    @default("") @map("create_by") @db.VarChar(64)
  createTime     DateTime? @default(now()) @map("create_time") @db.DateTime(6)
  updateBy       String    @default("") @map("update_by") @db.VarChar(64)
  updateTime     DateTime? @default(now()) @map("update_time") @db.DateTime(6)
  remark         String?   @db.VarChar(500)
  delFlag        String    @default("0") @map("del_flag") @db.Char(1)

  @@map("sys_job")
}

model SysJobLog {
  jobLogId      Int      @id @default(autoincrement()) @map("job_log_id")
  jobName       String   @map("job_name") @db.VarChar(64)
  jobGroup      String   @map("job_group") @db.VarChar(64)
  invokeTarget  String   @map("invoke_target") @db.VarChar(500)
  jobMessage    String?  @map("job_message") @db.VarChar(500)
  status        String   @default("0") @db.Char(1)
  exceptionInfo String?  @map("exception_info") @db.VarChar(2000)
  createTime    DateTime @default(now()) @map("create_time") @db.DateTime(6)

  @@map("sys_job_log")
}

model SysLogininfor {
  infoId        Int      @id @default(autoincrement()) @map("info_id")
  userName      String   @default("") @map("user_name") @db.VarChar(50)
  ipaddr        String   @default("") @db.VarChar(128)
  loginLocation String   @default("") @map("login_location") @db.VarChar(255)
  browser       String   @default("") @db.VarChar(50)
  os            String   @default("") @db.VarChar(50)
  status        String   @default("0") @db.Char(1)
  msg           String   @default("") @db.VarChar(255)
  delFlag       String   @default("0") @map("del_flag") @db.Char(1)
  loginTime     DateTime @default(now()) @map("login_time") @db.Timestamp(6)

  @@map("sys_logininfor")
}

model SysMenu {
  menuId       Int           @id @default(autoincrement()) @map("menu_id")
  menuName     String        @map("menu_name") @db.VarChar(50)
  parentId     Int           @map("parent_id")
  orderNum     Int           @default(0) @map("order_num")
  path         String        @default("") @db.VarChar(200)
  component    String?       @db.VarChar(255)
  query        String        @default("") @db.VarChar(255)
  isFrame      String        @default("1") @map("is_frame") @db.Char(1)
  isCache      String        @default("0") @map("is_cache") @db.Char(1)
  menuType     String        @default("M") @map("menu_type") @db.Char(1)
  visible      String        @default("0") @db.Char(1)
  status       String        @default("0") @db.Char(1)
  perms        String        @default("") @db.VarChar(100)
  icon         String        @default("") @db.VarChar(100)
  createBy     String        @default("") @map("create_by") @db.VarChar(64)
  createTime   DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy     String        @default("") @map("update_by") @db.VarChar(64)
  updateTime   DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark       String?       @db.VarChar(500)
  delFlag      String        @default("0") @map("del_flag") @db.Char(1)
  roleBindings SysRoleMenu[]

  @@map("sys_menu")
}

model SysNotice {
  noticeId      Int       @id @default(autoincrement()) @map("notice_id")
  noticeTitle   String    @default("") @map("notice_title") @db.VarChar(50)
  noticeType    String    @map("notice_type") @db.Char(1)
  noticeContent String?   @map("notice_content") @db.LongText
  status        String    @default("0") @db.Char(1)
  createBy      String    @default("") @map("create_by") @db.VarChar(64)
  createTime    DateTime? @default(now()) @map("create_time") @db.DateTime(6)
  updateBy      String    @default("") @map("update_by") @db.VarChar(64)
  updateTime    DateTime? @default(now()) @map("update_time") @db.DateTime(6)
  delFlag       String    @default("0") @map("del_flag") @db.Char(1)
  remark        String?   @db.VarChar(500)

  @@map("sys_notice")
}

model SysOperLog {
  operId        Int      @id @default(autoincrement()) @map("oper_id")
  title         String   @default("") @db.VarChar(50)
  businessType  Int      @default(0) @map("business_type")
  requestMethod String   @default("") @map("request_method") @db.VarChar(10)
  operName      String   @default("") @map("oper_name") @db.VarChar(50)
  deptName      String   @default("") @map("dept_name") @db.VarChar(50)
  operUrl       String   @default("") @map("oper_url") @db.VarChar(255)
  operLocation  String   @default("") @map("oper_location") @db.VarChar(255)
  operParam     String   @default("") @map("oper_param") @db.VarChar(2000)
  jsonResult    String   @default("") @map("json_result") @db.VarChar(2000)
  errorMsg      String   @default("") @map("error_msg") @db.VarChar(2000)
  method        String   @default("") @db.VarChar(100)
  operIp        String   @default("") @map("oper_ip") @db.VarChar(255)
  operTime      DateTime @default(now()) @map("oper_time") @db.Timestamp(6)
  status        String   @default("0") @db.Char(1)
  costTime      Int      @default(0) @map("cost_time")
  operatorType  String   @default("0") @map("operator_type") @db.VarChar(255)

  @@map("sys_oper_log")
}

model SysPost {
  postId       Int           @id @default(autoincrement()) @map("post_id")
  postCode     String        @map("post_code") @db.VarChar(64)
  postName     String        @map("post_name") @db.VarChar(50)
  postSort     Int           @default(0) @map("post_sort")
  status       String        @default("0") @db.Char(1)
  createBy     String        @default("") @map("create_by") @db.VarChar(64)
  createTime   DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy     String        @default("") @map("update_by") @db.VarChar(64)
  updateTime   DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark       String?       @db.VarChar(500)
  delFlag      String        @default("0") @map("del_flag") @db.Char(1)
  userBindings SysUserPost[]

  @@map("sys_post")
}

model SysRole {
  roleId            Int           @id @default(autoincrement()) @map("role_id")
  roleName          String        @map("role_name") @db.VarChar(30)
  roleKey           String        @map("role_key") @db.VarChar(100)
  roleSort          Int           @default(0) @map("role_sort")
  dataScope         String        @default("1") @map("data_scope") @db.Char(1)
  menuCheckStrictly Int           @default(0) @map("menu_check_strictly") @db.TinyInt
  deptCheckStrictly Int           @default(0) @map("dept_check_strictly") @db.TinyInt
  status            String        @default("0") @db.Char(1)
  delFlag           String        @default("0") @map("del_flag") @db.Char(1)
  createBy          String        @default("") @map("create_by") @db.VarChar(64)
  createTime        DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy          String        @default("") @map("update_by") @db.VarChar(64)
  updateTime        DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark            String?       @db.VarChar(500)
  deptBindings      SysRoleDept[]
  menuBindings      SysRoleMenu[]
  userBindings      SysUserRole[]

  @@map("sys_role")
}

model SysRoleDept {
  roleId Int     @default(0) @map("role_id")
  deptId Int     @default(0) @map("dept_id")
  role   SysRole @relation(fields: [roleId], references: [roleId])
  dept   SysDept @relation(fields: [deptId], references: [deptId])

  @@id([roleId, deptId])
  @@map("sys_role_dept")
}

model SysRoleMenu {
  roleId Int     @default(0) @map("role_id")
  menuId Int     @default(0) @map("menu_id")
  role   SysRole @relation(fields: [roleId], references: [roleId])
  menu   SysMenu @relation(fields: [menuId], references: [menuId])

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

model SysUpload {
  uploadId    String    @id @map("upload_id") @db.VarChar(255)
  status      String    @default("0") @db.Char(1)
  delFlag     String    @default("0") @map("del_flag") @db.Char(1)
  createBy    String    @default("") @map("create_by") @db.VarChar(64)
  createTime  DateTime? @default(now()) @map("create_time") @db.DateTime(6)
  updateBy    String    @default("") @map("update_by") @db.VarChar(64)
  updateTime  DateTime? @default(now()) @map("update_time") @db.DateTime(6)
  remark      String?   @db.VarChar(500)
  size        Int
  fileName    String    @map("file_name") @db.VarChar(255)
  newFileName String    @map("new_file_name") @db.VarChar(255)
  url         String    @db.VarChar(255)
  ext         String?   @db.VarChar(255)

  @@map("sys_upload")
}

model SysUser {
  userId       Int           @id @default(autoincrement()) @map("user_id")
  deptId       Int?          @map("dept_id")
  userName     String        @map("user_name") @db.VarChar(30)
  nickName     String        @map("nick_name") @db.VarChar(30)
  userType     String        @default("00") @map("user_type") @db.VarChar(2)
  email        String        @default("") @db.VarChar(50)
  phonenumber  String        @default("") @db.VarChar(11)
  sex          String        @default("0") @db.Char(1)
  password     String        @default("") @db.VarChar(200)
  status       String        @default("0") @db.Char(1)
  delFlag      String        @default("0") @map("del_flag") @db.Char(1)
  loginIp      String        @default("") @map("login_ip") @db.VarChar(128)
  createBy     String        @default("") @map("create_by") @db.VarChar(64)
  createTime   DateTime?     @default(now()) @map("create_time") @db.DateTime(6)
  updateBy     String        @default("") @map("update_by") @db.VarChar(64)
  updateTime   DateTime?     @default(now()) @map("update_time") @db.DateTime(6)
  remark       String?       @db.VarChar(500)
  avatar       String        @default("") @db.VarChar(255)
  loginDate    DateTime?     @map("login_date") @db.Timestamp(0)
  dept         SysDept?      @relation(fields: [deptId], references: [deptId])
  postBindings SysUserPost[]
  roleBindings SysUserRole[]

  @@map("sys_user")
}

model SysUserPost {
  userId Int     @map("user_id")
  postId Int     @map("post_id")
  user   SysUser @relation(fields: [userId], references: [userId])
  post   SysPost @relation(fields: [postId], references: [postId])

  @@id([userId, postId])
  @@map("sys_user_post")
}

model SysUserRole {
  userId Int     @map("user_id")
  roleId Int     @map("role_id")
  user   SysUser @relation(fields: [userId], references: [userId])
  role   SysRole @relation(fields: [roleId], references: [roleId])

  @@id([userId, roleId])
  @@map("sys_user_role")
}
